{
  "name": "@xroute/sdk",
  "version": "0.1.0",
  "description": "XRoute integration SDK for route discovery, source-chain execution, and hosted intent status tracking.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.mjs",
  "exports": {
    ".": "./dist/index.mjs",
    "./chains": "./dist/chains/index.mjs",
    "./routes": "./dist/routes/index.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "node scripts/build-package.mjs",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@noble/hashes": "2.0.1",
    "@scure/sr25519": "1.0.0",
    "@polkadot-api/metadata-builders": "0.13.9",
    "@polkadot-api/substrate-bindings": "0.17.0",
    "polkadot-api": "1.23.3"
  }
}
